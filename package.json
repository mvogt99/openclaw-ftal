{
  "name": "openclaw-ftal",
  "version": "0.2.0",
  "description": "Multi-dimensional reply quality scoring plugin for OpenClaw agents (Faithfulness / Truthfulness / Accuracy / Latency)",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./store": "./src/store.ts"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.0"
  },
  "devDependencies": {
    "openclaw": "*",
    "vitest": "^1.0.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.0"
    },
    "build": {
      "openclawVersion": "2026.4.23"
    },
    "release": {
      "publishToClawHub": true
    }
  }
}
